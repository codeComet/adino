    "testimonial": {
        "id": 177,
        "name": "Osita Maduagwu",
        "location_designation": "Chief Marketing Officer",
        "description": [
            {
                "type": "paragraph",
                "children": [
                    {
                        "type": "text",
                        "text": "Nigeria’s financial landscape presents a clear opportunity: businesses need better access to credit to scale, while investors require more flexible, high-quality avenues to deploy capital effectively and grow wealth. Adino Group was established in 2013 to bridge this gap."
                    }
                ]
            },
            {
                "type": "paragraph",
                "children": [
                    {
                        "type": "text",
                        "text": "Today, we operate as a diversified financial services group spanning investment holding, markets trading, asset & wealth management, deal structuring, credits, and real estate. Each member of our leadership team brings over 20 years of experience, with backgrounds across leading financial institutions, including GTBank, Ecobank, Access Bank, Standard Chartered, First Bank, and Nova Bank. This wealth of experience, combined with deep market knowledge and disciplined execution, provides us with the cutting edge required to excel in our chosen environment."
                    }
                ]
            }
        ],
